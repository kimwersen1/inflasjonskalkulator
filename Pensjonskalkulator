<script>
function beregnPensjon() {
  const pensjon = parseFloat(document.getElementById('pensjon').value);
  const aar = parseInt(document.getElementById('antall-aar').value);
  const inflasjon = parseFloat(document.getElementById('inflasjon-valg').value) / 100;
  const regulering = parseFloat(document.getElementById('regulering-valg').value) / 100;

  if (!pensjon || isNaN(pensjon) || !aar || isNaN(aar)) {
    document.getElementById('result-box').classList.remove('show', 'positiv', 'negativ');
    return;
  }

  // Netto realvekst per år
  const nettoVekst = regulering - inflasjon;
  // Realverdi om N år (i dagens kjøpekraft)
  const realFaktor = Math.pow(1 + nettoVekst, aar);
  const realVerdi = pensjon * realFaktor;
  // Nominell pensjon om N år (med regulering)
  const nominellFaktor = Math.pow(1 + regulering, aar);
  const nominell = pensjon * nominellFaktor;
  // Tap i kjøpekraft
  const tap = pensjon - realVerdi;
  const tapPst = ((1 - realFaktor) * 100);

  const fmt = n => Math.round(Math.abs(n)).toLocaleString('nb-NO') + ' kr';
  const fmtP = n => (n >= 0 ? '+' : '') + n.toFixed(1) + ' %';

  const positiv = realVerdi >= pensjon;
  const box = document.getElementById('result-box');
  box.className = 'result-box show ' + (positiv ? 'positiv' : 'negativ');

  const valEl = document.getElementById('res-kjopekraft');
  valEl.textContent = fmt(realVerdi) + '/mnd';
  valEl.className = 'result-val ' + (positiv ? 'pos' : 'neg');

  document.getElementById('res-lbl').innerHTML = `Reell kjøpekraft om <span id="res-aar-lbl">${aar}</span> år (i dagens kroner)`;
  document.getElementById('res-nominell').textContent = fmt(nominell) + '/mnd';
  document.getElementById('res-tap').textContent = (positiv ? '+' : '-') + fmt(tap) + '/mnd';
  document.getElementById('res-tap').className = 'val ' + (positiv ? '' : 'neg');
  document.getElementById('res-pst').textContent = fmtP(tapPst);
  document.getElementById('res-pst').className = 'val ' + (positiv ? '' : 'neg');

  const infPst = (inflasjon * 100).toFixed(1).replace('.', ',');
  const regPst = (regulering * 100).toFixed(1).replace('.', ',');

  document.getElementById('res-tekst').textContent =
    `Med ${infPst} % årlig inflasjon og ${regPst} % pensjonsregulering vil ${fmt(pensjon)}/mnd i dag ha en reell kjøpekraft på ${fmt(realVerdi)}/mnd om ${aar} år. ` +
    (positiv
      ? `Pensjonen din øker i reell verdi fordi reguleringen er høyere enn inflasjonen.`
      : `Det tilsvarer et kjøpekrafttap på ${fmt(tap)} per måned – eller ${fmt(tap * 12)} per år.`);
}

document.getElementById('pensjon').addEventListener('keydown', e => { if (e.key === 'Enter') beregnPensjon(); });
</script>
